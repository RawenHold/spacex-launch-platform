# Database
# PostgreSQL connection string. Supabase Postgres, local Postgres, Neon, or Prisma Postgres all work.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Optional direct database URL for providers that use poolers for DATABASE_URL.
# Prisma migrations may need a non-pooled connection in some hosted Postgres setups.
DIRECT_URL=""

# Auth.js
# Generate with: npx auth secret
AUTH_SECRET=""
AUTH_TRUST_HOST=true

# Local seed bootstrap. ADMIN_PASSWORD is optional; without it, the seeded user cannot use credentials login.
ADMIN_EMAIL="admin@example.local"
ADMIN_NAME="Dev Admin"
ADMIN_PASSWORD=""

# Local-only public fallback. Set to false to force empty states when no published DB data exists.
ENABLE_MOCK_FALLBACK="true"

# External launch data sync. Manual admin-triggered sync only; imported records stay unpublished.
LAUNCH_LIBRARY_BASE_URL="https://ll.thespacedevs.com/2.3.0"
LAUNCH_LIBRARY_API_KEY=""
ENABLE_EXTERNAL_SYNC="false"

# Optional Supabase placeholders for a future Supabase Auth/client migration.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Future AI integration placeholder.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
ENABLE_AI_DRAFTS="false"

# YouTube Data API v3 discovery. Manual admin-triggered discovery only; videos stay unpublished until approved.
YOUTUBE_API_KEY=""
YOUTUBE_SPACEX_CHANNEL_ID=""
ENABLE_YOUTUBE_SYNC="false"
